{
  "name": "quilon",
  "displayName": "Quilon",
  "description": "Syntax highlighting and editor tasks for the Quilon programming language (.ql).",
  "version": "0.1.0",
  "publisher": "quilon",
  "license": "GPL-2.0-only",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/assapir/quilon.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "quilon",
    "ql",
    "language"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "pnpm run compile && node --test \"out/**/*.test.js\"",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.75.1",
    "@vscode/vsce": "^3.9.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "quilon",
        "aliases": [
          "Quilon",
          "quilon"
        ],
        "extensions": [
          ".ql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "quilon",
        "scopeName": "source.quilon",
        "path": "./syntaxes/quilon.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "quilon.check",
        "title": "Quilon: Check Current File"
      },
      {
        "command": "quilon.run",
        "title": "Quilon: Run Current File"
      }
    ],
    "taskDefinitions": [
      {
        "type": "quilon"
      }
    ],
    "configuration": {
      "title": "Quilon",
      "properties": {
        "quilon.command": {
          "type": "string",
          "default": "quilon",
          "description": "How to invoke the Quilon compiler. Use \"quilon\" if the binary is on your PATH, or e.g. \"cargo run --\" to run from a checkout of the compiler repo."
        }
      }
    }
  }
}
