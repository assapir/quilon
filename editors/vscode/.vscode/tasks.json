{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "quilon: check current file",
      "type": "shell",
      "command": "quilon",
      "args": ["check", "${file}"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "quilon: run current file",
      "type": "shell",
      "command": "quilon",
      "args": ["run", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
