{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "detail": "Type-check and emit the extension JS into out/ (preLaunchTask for F5).",
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "watch",
      "detail": "Incrementally recompile the extension on change.",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "quilon: check current file",
      "type": "shell",
      "command": "quilon",
      "args": ["check", "${file}"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "quilon: run current file",
      "type": "shell",
      "command": "quilon",
      "args": ["run", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
